{
    "name": "@somewhatabstract/x",
    "private": false,
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "bin": {
        "x": "./dist/x.mjs"
    },
    "files": [
        "dist"
    ],
    "type": "module",
    "version": "0.3.0",
    "description": "Execute any bin defined by any package in a monorepo without needing to install that package",
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "biome check",
        "lint:fix": "biome check --write --unsafe",
        "typecheck": "tsc --noEmit --project tsconfig.json",
        "typewatch": "pnpm typecheck --watch",
        "test": "vitest",
        "coverage": "vitest run --coverage",
        "prepack": "node scripts/pack-readme.mjs rewrite",
        "postpack": "node scripts/pack-readme.mjs restore",
        "prepublishOnly": "pnpm build",
        "publish:ci": "git diff --stat --exit-code HEAD && pnpm build && changeset publish"
    },
    "bugs": {
        "url": "https://github.com/somewhatabstract/x/issues"
    },
    "repository": "https://github.com/somewhatabstract/x",
    "author": "Jeff Yates <jeff@somewhatabstract.com>",
    "keywords": [],
    "license": "MIT",
    "packageManager": "pnpm@11.0.0+sha512.5bd187500e49cc6c3d891d973b432c02b844a5eb7209172c90a517a3ef4f579ed5c23d409b699e6a9dc418ff7b2b1890e63f6d74f1d3fc49848f37779c89c84c",
    "engines": {
        "node": ">= 24",
        "npm": "please-use-pnpm",
        "yarn": "please-use-pnpm"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.6",
        "@changesets/cli": "^2.29.8",
        "@codecov/rollup-plugin": "^2.0.1",
        "@types/node": "^24.12.2",
        "@types/yargs": "^17.0.35",
        "@vitest/coverage-v8": "^4.0.17",
        "fast-glob": "^3.3.3",
        "tsdown": "0.21.10",
        "typescript": "^6.0.3",
        "vitest": "^4.0.17"
    },
    "dependencies": {
        "@manypkg/find-root": "^3.1.0",
        "@manypkg/get-packages": "^3.1.0",
        "yargs": "^18.0.0"
    }
}
